<Window x:Class="EisenhowerMatrix.Views.TaskEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:antd="https://antdesign.wpf/"
        xmlns:models="clr-namespace:EisenhowerMatrix.Models"
        Title="{Binding DialogTitle}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="440"
        Background="{DynamicResource AntDesign.Brush.Bg.Container}"
        ShowInTaskbar="False">

    <Border Padding="24,16">
        <StackPanel>
            <!-- Title -->
            <TextBlock Text="标题 *" Foreground="{DynamicResource AntDesign.Brush.Text}"
                       FontSize="{DynamicResource AntDesign.FontSize}" Margin="0,8,0,4"/>
            <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                     Padding="8,6" FontSize="{DynamicResource AntDesign.FontSize}"/>
            <TextBlock Text="{Binding TitleError}" Foreground="#EF4444"
                       FontSize="{DynamicResource AntDesign.FontSize.SM}" Margin="0,2,0,0"/>

            <!-- Quadrant -->
            <TextBlock Text="象限" Foreground="{DynamicResource AntDesign.Brush.Text}"
                       FontSize="{DynamicResource AntDesign.FontSize}" Margin="0,8,0,4"/>
            <ComboBox SelectedValue="{Binding Quadrant}"
                      SelectedValuePath="Tag">
                <ComboBoxItem Content="Q1 重要&amp;紧急" Tag="{x:Static models:QuadrantType.Q1}"/>
                <ComboBoxItem Content="Q2 重要&amp;不紧急" Tag="{x:Static models:QuadrantType.Q2}"/>
                <ComboBoxItem Content="Q3 不重要&amp;紧急" Tag="{x:Static models:QuadrantType.Q3}"/>
                <ComboBoxItem Content="Q4 不重要&amp;不紧急" Tag="{x:Static models:QuadrantType.Q4}"/>
            </ComboBox>

            <!-- Owner -->
            <TextBlock Text="负责人" Foreground="{DynamicResource AntDesign.Brush.Text}"
                       FontSize="{DynamicResource AntDesign.FontSize}" Margin="0,8,0,4"/>
            <TextBox Text="{Binding Owner, UpdateSourceTrigger=PropertyChanged}"
                     Padding="8,6" FontSize="{DynamicResource AntDesign.FontSize}"/>

            <!-- Estimate -->
            <TextBlock Text="预估工期" Foreground="{DynamicResource AntDesign.Brush.Text}"
                       FontSize="{DynamicResource AntDesign.FontSize}" Margin="0,8,0,4"/>
            <TextBox Text="{Binding Estimate, UpdateSourceTrigger=PropertyChanged}"
                     Padding="8,6" FontSize="{DynamicResource AntDesign.FontSize}"
                     ToolTip="如：3天、1周"/>

            <!-- Status -->
            <TextBlock Text="状态" Foreground="{DynamicResource AntDesign.Brush.Text}"
                       FontSize="{DynamicResource AntDesign.FontSize}" Margin="0,8,0,4"/>
            <ComboBox SelectedValue="{Binding Status}"
                      SelectedValuePath="Tag">
                <ComboBoxItem Content="未开始" Tag="{x:Static models:TaskItemStatus.NotStarted}"/>
                <ComboBoxItem Content="进行中" Tag="{x:Static models:TaskItemStatus.InProgress}"/>
                <ComboBoxItem Content="已完成" Tag="{x:Static models:TaskItemStatus.Completed}"/>
                <ComboBoxItem Content="阻塞" Tag="{x:Static models:TaskItemStatus.Blocked}"/>
            </ComboBox>

            <!-- Blocker -->
            <TextBlock Text="阻塞点" Foreground="{DynamicResource AntDesign.Brush.Text}"
                       FontSize="{DynamicResource AntDesign.FontSize}" Margin="0,8,0,4"/>
            <TextBox Text="{Binding Blocker, UpdateSourceTrigger=PropertyChanged}"
                     Padding="8,6" FontSize="{DynamicResource AntDesign.FontSize}"
                     AcceptsReturn="True" TextWrapping="Wrap" Height="60"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="取消" Click="Cancel_Click"
                        Style="{StaticResource AntDesignDefaultButton}" Margin="0,0,8,0"/>
                <Button Content="保存" Click="Save_Click"
                        Style="{StaticResource AntDesignPrimaryButton}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
