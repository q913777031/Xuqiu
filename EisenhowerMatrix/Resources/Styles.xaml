<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Quadrant Colors -->
    <SolidColorBrush x:Key="Q1Brush" Color="#EF4444"/>
    <SolidColorBrush x:Key="Q2Brush" Color="#F97316"/>
    <SolidColorBrush x:Key="Q3Brush" Color="#3B82F6"/>
    <SolidColorBrush x:Key="Q4Brush" Color="#9CA3AF"/>

    <SolidColorBrush x:Key="Q1BgBrush" Color="#FEF2F2"/>
    <SolidColorBrush x:Key="Q2BgBrush" Color="#FFF7ED"/>
    <SolidColorBrush x:Key="Q3BgBrush" Color="#EFF6FF"/>
    <SolidColorBrush x:Key="Q4BgBrush" Color="#F9FAFB"/>

    <!-- Status Tag Style -->
    <Style x:Key="StatusTagStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="Margin" Value="0,0,4,0"/>
    </Style>

    <!-- Icon Button (Edit/Delete on cards) -->
    <Style x:Key="IconButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource AntDesign.Brush.Text.Secondary}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="4,2"/>
        <Setter Property="Opacity" Value="0.6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="{DynamicResource AntDesign.CornerRadius.XS}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="1"/>
                            <Setter Property="Background" Value="{DynamicResource AntDesign.Brush.Primary.Bg}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
